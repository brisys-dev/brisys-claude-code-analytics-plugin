    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/send-hook-event.mjs",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
